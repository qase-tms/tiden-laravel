{
    "name": "tiden/telemetry-laravel",
    "description": "Tiden error tracking for Laravel — auto-captures reported exceptions and sends them to your Tiden project. Built on tiden/telemetry-php.",
    "keywords": ["tiden", "laravel", "error-tracking", "exceptions", "sdk"],
    "homepage": "https://github.com/qase-tms/tiden-telemetry-laravel",
    "support": {
        "issues": "https://github.com/qase-tms/tiden-telemetry-laravel/issues",
        "source": "https://github.com/qase-tms/tiden-telemetry-laravel"
    },
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "tiden/telemetry-php": "^0.1",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Tiden\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tiden\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tiden\\Laravel\\TidenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "lint": "pint --test",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
