{
    "name": "tiden/laravel",
    "description": "Tiden error tracking for Laravel — auto-captures reported exceptions and sends them to your Tiden project. Built on tiden/php.",
    "keywords": ["tiden", "laravel", "error-tracking", "exceptions", "sdk"],
    "homepage": "https://github.com/qase-tms/tiden-laravel",
    "support": {
        "issues": "https://github.com/qase-tms/tiden-laravel/issues",
        "source": "https://github.com/qase-tms/tiden-laravel"
    },
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "tiden/php": "^0.1",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5 || ^11.5"
    },
    "autoload": {
        "psr-4": {
            "Tiden\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tiden\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tiden\\Laravel\\TidenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
